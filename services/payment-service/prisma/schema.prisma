generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Payment {
  id                   String        @id @default(uuid())
  jobId                String
  customerId           String
  amount               Float
  currency             String
  providerOrderId      String
  gatewayTransactionId String?
  status               PaymentStatus
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  invoices             Invoice[]
  refunds              Refund[]

  @@map("payments")
}

model Invoice {
  id            String   @id @default(uuid())
  paymentId     String
  invoiceNumber String
  amount        Float
  createdAt     DateTime @default(now())
  payment       Payment  @relation(fields: [paymentId], references: [id])

  @@map("invoices")
}

model Refund {
  id        String   @id @default(uuid())
  paymentId String
  amount    Float
  reason    String?
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id])

  @@map("refunds")
}
